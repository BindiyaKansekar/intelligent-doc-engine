# Copy this file to .env and fill in your values
# Never commit .env to version control

# Anthropic API Key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Azure DevOps Wiki Integration ────────────────────────────────────────────
# These are only needed if you run publish_to_wiki.py locally.
# In Azure DevOps Pipelines, set these as pipeline variables instead.

# Your Azure DevOps organisation URL (no trailing slash)
ADO_ORG_URL=https://dev.azure.com/your-org

# Azure DevOps project name
ADO_PROJECT=YourProject

# Wiki identifier — found in the URL when viewing your wiki:
#   https://dev.azure.com/{org}/{project}/_wiki/wikis/{ADO_WIKI_ID}
ADO_WIKI_ID=YourProject.wiki

# The wiki page path to create or update (use forward slashes)
ADO_WIKI_PAGE_PATH=/Documentation/AUD

# Personal Access Token for local use (needs Wiki Read+Write permission)
# In the pipeline, $(System.AccessToken) is used automatically — no PAT needed.
SYSTEM_ACCESSTOKEN=your-personal-access-token
